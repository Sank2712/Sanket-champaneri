rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /leads/{leadId} {
      allow read, write: if true;
    }

    match /testimonials/{testimonialId} {
      allow read, write: if true;
    }

    match /visitor_book/{entryId} {
      allow read, write: if true;
    }
  }
}
